{
  "name": "excalidraw-skill",
  "version": "1.0.0",
  "description": "Excalidraw diagram generator skill — converts skeleton definitions to .excalidraw files and renders PNG previews",
  "type": "module",
  "scripts": {
    "build": "node build/bundle-excalidraw.mjs && node build/build-preview.mjs",
    "build:lib": "node build/bundle-excalidraw.mjs",
    "build:preview": "node build/build-preview.mjs",
    "deploy": "node build/deploy.mjs"
  },
  "engines": {
    "node": ">=25.5.0"
  },
  "license": "ISC",
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@excalidraw/utils": "^0.1.3-test32",
    "@resvg/resvg-js": "^2.6.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "postject": "^1.0.0-alpha.6"
  }
}
